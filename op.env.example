# GitHub 認証用の環境変数テンプレート
# このファイルを op.env にコピーして実際の値を設定してください
#   cp op.env.example op.env
#
# GITHUB_USERNAME: GitHubのユーザー名（またはBotアカウント名）
# GITHUB_TOKEN: 1Password の参照パス（op:// 形式）
#   書式: op://<Vault名>/<アイテム名>/credential
#   ※ Vault名・アイテム名にスペースが含まれる場合はダブルクォートで囲む
#   例（スペースなし）: op://Private/GitHubPAT/credential
#   例（スペースあり）: "op://Private/My GitHub PAT/credential"

GITHUB_USERNAME=<GitHubユーザー名>
GITHUB_TOKEN=op://<Vault名>/<アイテム名>/credential
